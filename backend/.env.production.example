# ==========================================
# ENTORNO
# ==========================================
NODE_ENV=production
PORT=3001
DEBUG_ERRORS=false
TRUST_PROXY=true
JSON_BODY_LIMIT=1mb

# ==========================================
# BASE DE DATOS
# ==========================================
SQLITE_PATH=./database_prod_rutadelnido_2026_04.sqlite

# ==========================================
# SEGURIDAD
# ==========================================
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_COMPLETELY_RANDOM_SECRET_STRING_HERE
JWT_ISSUER=ruta-fresca-backend
JWT_AUDIENCE=ruta-fresca-clients
CRM_JWT_AUDIENCE=ruta-fresca-crm
AUTH_JWT_EXPIRES=30d
AUTH_COOKIE_NAME=rdn_auth_token
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true
CRM_JWT_EXPIRES=8h

# ==========================================
# CRM
# ==========================================
CRM_LOGIN_EMAIL=admin@tu-dominio.com
CRM_LOGIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
CRM_OPERATOR_EMAIL=operador@tu-dominio.com
CRM_OPERATOR_PASSWORD=CHANGE_ME_STRONG_OPERATOR_PASSWORD

# ==========================================
# CORS Y RATE LIMIT
# ==========================================
CORS_ORIGINS=https://rutadelnido.com,https://www.rutadelnido.com
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300

# ==========================================
# IA
# ==========================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ALCHEMIST_GEMINI_MODEL=gemini-2.5-flash
CHEF_ACCESS_CODE=

# ==========================================
# EMAILS
# ==========================================
RESEND_API_KEY=
REPORT_EMAIL_FROM=noreply@tudominio.com
APP_BASE_URL=https://tudominio.com

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info

# ==========================================
# ANALYTICS
# ==========================================
ANALYTICS_GEO_MODE=mock
ANALYTICS_GEO_PROVIDER=ip-api
ANALYTICS_GEO_TIMEOUT_MS=3000
ANALYTICS_TRACK_INTERNAL=false
ANALYTICS_PAYLOAD_MAX_BYTES=4096
ANALYTICS_RETENTION_DAYS=180
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_RATE_LIMIT_MAX=120
ANALYTICS_IP_HASH_SALT=CHANGE_ME_ANALYTICS_HASH_SALT
